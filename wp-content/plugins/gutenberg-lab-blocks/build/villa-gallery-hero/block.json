{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenberg-lab-blocks/villa-gallery-hero",
  "version": "0.1.1",
  "title": "Villa Gallery Hero",
  "category": "design",
  "icon": "format-gallery",
  "description": "A synced villa hero with a main media stage, thumbnail rail, and native overlay content.",
  "keywords": [
    "villa",
    "hero",
    "gallery",
    "slider"
  ],
  "attributes": {
    "heroHeight": {
      "type": "string",
      "default": "full"
    },
    "overlayStyle": {
      "type": "string",
      "default": "brand-green"
    },
    "showArrows": {
      "type": "boolean",
      "default": false
    },
    "arrowPositionPreset": {
      "type": "string",
      "default": "center"
    },
    "arrowOffsetX": {
      "type": "number",
      "default": 0
    },
    "arrowOffsetY": {
      "type": "number",
      "default": 0
    },
    "thumbArrowPositionPreset": {
      "type": "string",
      "default": "center"
    },
    "thumbArrowOffsetX": {
      "type": "number",
      "default": 0
    },
    "thumbArrowOffsetY": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "anchor": true,
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true
    }
  },
  "textdomain": "gutenberg-lab-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js"
}