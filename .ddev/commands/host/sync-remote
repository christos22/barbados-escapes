#!/usr/bin/env bash
## Description: Refresh local DB/uploads from the live InMotion WordPress site
## Usage: sync-remote [--db-only] [--uploads-only] [--mirror-uploads] [--skip-snapshot] [--dry-run]
## Example: "ddev sync-remote --db-only"

set -euo pipefail

APPROOT="${DDEV_APPROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)}"
ENV_FILE="${APPROOT}/.ddev/.env.sync-remote"
ENV_EXAMPLE_FILE="${APPROOT}/.ddev/.env.sync-remote.example"
LOCAL_UPLOADS_PATH="${APPROOT}/wp-content/uploads"
LOCAL_WP_CONFIG_OVERRIDE="${APPROOT}/wp-config-ddev-local.php"
SSH_KEY_PATH="/home/Quester/Nextcloud/Documents/Development/Server/SSH-Keys/inmotion"
WP_CLI_MAINTENANCE_ARGS=(--skip-plugins --skip-themes)
SSH_COMMON_ARGS=(-o BatchMode=yes -o ConnectTimeout=10)
RSYNC_SSH_COMMAND="ssh -o BatchMode=yes -o ConnectTimeout=10"
SSH_RETRY_COUNT=3
SSH_RETRY_DELAY=3

sync_db=1
sync_uploads=1
mirror_uploads=0
skip_snapshot=0
dry_run=0
snapshot_name=""
temp_dump=""

log() {
	printf '\n==> %s\n' "$*"
}

fail() {
	printf 'Error: %s\n' "$*" >&2
	exit 1
}

run_with_retries() {
	local max_attempts="$1"
	local delay_seconds="$2"
	local attempt=1
	local exit_code=0
	shift 2

	while true; do
		"$@"
		exit_code=$?
		if (( exit_code == 0 )); then
			return 0
		fi
		if (( attempt >= max_attempts )); then
			return "${exit_code}"
		fi

		printf 'Warning: command failed with exit code %s. Retrying in %ss (%s/%s)...\n' \
			"${exit_code}" "${delay_seconds}" "${attempt}" "${max_attempts}" >&2
		sleep "${delay_seconds}"
		attempt=$(( attempt + 1 ))
	done
}

ssh_run() {
	run_with_retries "${SSH_RETRY_COUNT}" "${SSH_RETRY_DELAY}" \
		ssh "${SSH_COMMON_ARGS[@]}" "$@"
}

run_remote_dump() {
	local remote_host="$1"
	local remote_command="$2"
	local output_file="$3"
	local attempt=1
	local exit_code=0

	while true; do
		: > "${output_file}"

		if ssh "${SSH_COMMON_ARGS[@]}" "${remote_host}" \
			"bash -lc $(printf '%q' "${remote_command}")" > "${output_file}"; then
			if [[ -s "${output_file}" ]] && gzip -t "${output_file}" >/dev/null 2>&1; then
				return 0
			fi
			exit_code=1
		else
			exit_code=$?
		fi

		if (( attempt >= SSH_RETRY_COUNT )); then
			return "${exit_code}"
		fi

		printf 'Warning: remote dump failed. Retrying in %ss (%s/%s)...\n' \
			"${SSH_RETRY_DELAY}" "${attempt}" "${SSH_RETRY_COUNT}" >&2
		sleep "${SSH_RETRY_DELAY}"
		attempt=$(( attempt + 1 ))
	done
}

require_nonempty_var() {
	local var_name="$1"
	[[ -n "${!var_name:-}" ]] || fail "Missing ${var_name} in ${ENV_FILE}"
}

require_set_var() {
	local var_name="$1"
	[[ "${!var_name+x}" ]] || fail "Missing ${var_name} in ${ENV_FILE}"
}

detect_imported_table_prefix() {
	local options_table
	options_table="$(ddev mysql -N -e "SHOW TABLES" | awk '/_options$/ { print; exit }')"
	[[ -n "${options_table}" ]] || fail "Could not detect the imported WordPress table prefix from the local database."

	printf '%s\n' "${options_table%options}"
}

write_local_table_prefix_override() {
	local detected_prefix="$1"

	[[ "${detected_prefix}" == *_ ]] || fail "Detected table prefix '${detected_prefix}' was not in the expected format."

	if [[ "${detected_prefix}" == "wp_" ]]; then
		rm -f "${LOCAL_WP_CONFIG_OVERRIDE}"
		log "Using the default local table prefix wp_"
		return
	fi

	cat > "${LOCAL_WP_CONFIG_OVERRIDE}" <<EOF
<?php
/**
 * Local-only DDEV overrides generated by ddev sync-remote.
 *
 * This keeps the tracked wp-config-ddev.php stable even when the imported
 * live database uses a non-wp_ table prefix.
 */

\$table_prefix = '$(printf "%s" "${detected_prefix}" | sed "s/'/'\\\\''/g")';
EOF

	log "Wrote local table prefix override ${LOCAL_WP_CONFIG_OVERRIDE} (${detected_prefix})"
}

ensure_local_table_prefix_hook() {
	local wp_config_ddev="${APPROOT}/wp-config-ddev.php"
	local temp_config=""
	local table_prefix_comment_line=""
	local table_prefix_comment_start_line=""

	[[ -f "${wp_config_ddev}" ]] || fail "Missing ${wp_config_ddev}. Start DDEV once so the local WordPress config exists."

	if grep -q "wp-config-ddev-local.php" "${wp_config_ddev}"; then
		return
	fi

	table_prefix_comment_line="$(grep -n "Set WordPress Database Table prefix if not already set." "${wp_config_ddev}" | head -n 1 | cut -d: -f1)"
	[[ -n "${table_prefix_comment_line}" ]] || fail "Could not find the table prefix section in ${wp_config_ddev}."
	table_prefix_comment_start_line="$(awk -v end_line="${table_prefix_comment_line}" 'NR <= end_line && /^[[:space:]]*\/\*\*/ { line = NR } END { if ( line ) print line }' "${wp_config_ddev}")"
	[[ -n "${table_prefix_comment_start_line}" ]] || fail "Could not find the start of the table prefix comment in ${wp_config_ddev}."

	temp_config="$(mktemp "${TMPDIR:-/tmp}/barbados-wp-config-ddev.XXXXXX.php")"
	head -n "$(( table_prefix_comment_start_line - 1 ))" "${wp_config_ddev}" > "${temp_config}"
	cat >> "${temp_config}" <<'EOF'

	/**
	 * Allow ignored local overrides so imported remote databases with
	 * non-default table prefixes can boot in DDEV without editing tracked config.
	 */
	$ddev_local_settings = __DIR__ . '/wp-config-ddev-local.php';
	if ( is_readable( $ddev_local_settings ) ) {
		require $ddev_local_settings;
	}
EOF
	tail -n "+${table_prefix_comment_start_line}" "${wp_config_ddev}" >> "${temp_config}"

	mv "${temp_config}" "${wp_config_ddev}"
	log "Patched local wp-config-ddev.php to load wp-config-ddev-local.php"
}

usage() {
	cat <<'EOF'
Refresh the local DDEV database and uploads from the live InMotion WordPress site.

Usage:
  ddev sync-remote [flags]

Flags:
  --db-only          Refresh only the database
  --uploads-only     Refresh only uploads
  --mirror-uploads   Mirror uploads exactly with rsync --delete
  --skip-snapshot    Skip the pre-import DDEV database snapshot
  --dry-run          Validate SSH and remote paths without importing data
  -h, --help         Show this help text

Before running:
  1. Copy .ddev/.env.sync-remote.example to .ddev/.env.sync-remote
  2. Fill in the live database credentials
  3. Load the local SSH key into ssh-agent:
     ssh-add /home/Quester/Nextcloud/Documents/Development/Server/SSH-Keys/inmotion
EOF
}

cleanup() {
	if [[ -n "${temp_dump}" && -f "${temp_dump}" ]]; then
		rm -f "${temp_dump}"
	fi
}
trap cleanup EXIT

while [[ $# -gt 0 ]]; do
	case "$1" in
		--db-only)
			sync_db=1
			sync_uploads=0
			;;
		--uploads-only)
			sync_db=0
			sync_uploads=1
			;;
		--mirror-uploads)
			mirror_uploads=1
			;;
		--skip-snapshot)
			skip_snapshot=1
			;;
		--dry-run)
			dry_run=1
			;;
		-h|--help)
			usage
			exit 0
			;;
		*)
			fail "Unknown argument: $1"
			;;
	esac
	shift
done

if (( sync_db == 0 && sync_uploads == 0 )); then
	fail "Nothing to do. Choose either DB sync, uploads sync, or both."
fi

for required_command in ddev ssh rsync gzip mktemp; do
	command -v "${required_command}" >/dev/null 2>&1 || fail "Missing required command: ${required_command}"
done

if (( sync_db )); then
	command -v mysqldump >/dev/null 2>&1 || fail "Missing required command: mysqldump"
fi

[[ -f "${ENV_FILE}" ]] || fail "Missing ${ENV_FILE}. Copy ${ENV_EXAMPLE_FILE} and fill in the real remote DB credentials."

# shellcheck disable=SC1090
set -a
source "${ENV_FILE}"
set +a

for required_var in REMOTE_SSH_HOST REMOTE_WP_PATH; do
	require_nonempty_var "${required_var}"
done

if (( sync_db && dry_run == 0 )); then
	for required_var in REMOTE_DB_HOST REMOTE_DB_NAME REMOTE_DB_USER REMOTE_SITE_URL LOCAL_SITE_URL; do
		require_nonempty_var "${required_var}"
	done
	require_set_var "REMOTE_DB_PASSWORD"
fi

REMOTE_SITE_URL="${REMOTE_SITE_URL:-}"
LOCAL_SITE_URL="${LOCAL_SITE_URL:-}"
REMOTE_SITE_URL="${REMOTE_SITE_URL%/}"
LOCAL_SITE_URL="${LOCAL_SITE_URL%/}"
REMOTE_UPLOADS_PATH="${REMOTE_WP_PATH%/}/wp-content/uploads/"

if ! ssh_run "${REMOTE_SSH_HOST}" 'echo ok' >/dev/null 2>&1; then
	fail "SSH authentication failed for ${REMOTE_SSH_HOST}. Unlock the key first with: ssh-add ${SSH_KEY_PATH}"
fi

quoted_remote_wp_path=$(printf '%q' "${REMOTE_WP_PATH}")

log "Validating remote WordPress path"
ssh_run "${REMOTE_SSH_HOST}" "test -d ${quoted_remote_wp_path}"

if (( sync_uploads )); then
	log "Validating remote uploads path"
	if (( dry_run )); then
		run_with_retries "${SSH_RETRY_COUNT}" "${SSH_RETRY_DELAY}" \
			rsync -azn -e "${RSYNC_SSH_COMMAND}" "${REMOTE_SSH_HOST}:${REMOTE_UPLOADS_PATH}" "${LOCAL_UPLOADS_PATH}/"
	else
		ssh_run "${REMOTE_SSH_HOST}" "test -d $(printf '%q' "${REMOTE_UPLOADS_PATH}")"
	fi
fi

if (( dry_run )); then
	log "Dry run succeeded. SSH and remote paths look good."
	exit 0
fi

if (( sync_db && skip_snapshot == 0 )); then
	snapshot_name="pre-sync-remote-$(date +%Y%m%d-%H%M%S)"
	log "Creating local database snapshot ${snapshot_name}"
	ddev snapshot --name "${snapshot_name}"
fi

if (( sync_db )); then
	temp_dump="$(mktemp "${TMPDIR:-/tmp}/barbados-sync-remote.XXXXXX.sql.gz")"
	quoted_remote_db_name=$(printf '%q' "${REMOTE_DB_NAME}")
	quoted_remote_db_user=$(printf '%q' "${REMOTE_DB_USER}")
	quoted_remote_db_password=$(printf '%q' "${REMOTE_DB_PASSWORD}")
	remote_db_host="${REMOTE_DB_HOST}"
	remote_db_port=""
	remote_db_socket=""

	# WordPress often stores DB_HOST as host:port. mysqldump needs those split.
	if [[ "${remote_db_host}" == *:* && "${remote_db_host}" != /* ]]; then
		remote_db_port="${remote_db_host##*:}"
		remote_db_host="${remote_db_host%:*}"
	fi

	# Support socket-style DB_HOST values as well.
	if [[ "${remote_db_host}" == /* ]]; then
		remote_db_socket="${remote_db_host}"
		remote_db_host="localhost"
	fi

	quoted_remote_db_host=$(printf '%q' "${remote_db_host}")
	quoted_remote_db_port=$(printf '%q' "${remote_db_port}")
	quoted_remote_db_socket=$(printf '%q' "${remote_db_socket}")
	dump_connection_args="-h ${quoted_remote_db_host}"

	if [[ -n "${remote_db_port}" ]]; then
		dump_connection_args="${dump_connection_args} -P ${quoted_remote_db_port}"
	fi

	if [[ -n "${remote_db_socket}" ]]; then
		dump_connection_args="${dump_connection_args} --socket=${quoted_remote_db_socket}"
	fi

	remote_dump_command="set -o pipefail; cd ${quoted_remote_wp_path} && MYSQL_PWD=${quoted_remote_db_password} mysqldump ${dump_connection_args} -u ${quoted_remote_db_user} --single-transaction --quick --default-character-set=utf8mb4 ${quoted_remote_db_name} | gzip -c"
	log "Dumping the remote database"
	run_remote_dump "${REMOTE_SSH_HOST}" "${remote_dump_command}" "${temp_dump}"
	[[ -s "${temp_dump}" ]] || fail "Remote dump was empty. Check the DB credentials in ${ENV_FILE}."
	gzip -t "${temp_dump}" || fail "Remote dump was not a valid gzip archive. Check the DB credentials in ${ENV_FILE}."

	log "Importing the remote database into DDEV"
	ddev import-db --file="${temp_dump}"

	ensure_local_table_prefix_hook
	imported_table_prefix="$(detect_imported_table_prefix)"
	write_local_table_prefix_override "${imported_table_prefix}"

	log "Updating local WordPress URLs"
	ddev wp core is-installed "${WP_CLI_MAINTENANCE_ARGS[@]}" >/dev/null
	ddev wp search-replace "${REMOTE_SITE_URL}" "${LOCAL_SITE_URL}" "${WP_CLI_MAINTENANCE_ARGS[@]}" --skip-columns=guid --all-tables
	if [[ "${REMOTE_SITE_URL}" == https://* ]]; then
		ddev wp search-replace "http://${REMOTE_SITE_URL#https://}" "${LOCAL_SITE_URL}" "${WP_CLI_MAINTENANCE_ARGS[@]}" --skip-columns=guid --all-tables
	fi
	ddev wp option update home "${LOCAL_SITE_URL}" "${WP_CLI_MAINTENANCE_ARGS[@]}"
	ddev wp option update siteurl "${LOCAL_SITE_URL}" "${WP_CLI_MAINTENANCE_ARGS[@]}"

	permalink_structure="$(ddev wp option get permalink_structure "${WP_CLI_MAINTENANCE_ARGS[@]}" 2>/dev/null || true)"
	if [[ -n "${permalink_structure}" ]]; then
		log "Flushing local rewrite rules"
		ddev wp rewrite flush
	else
		log "Skipping rewrite flush because permalink_structure is empty"
	fi
fi

if (( sync_uploads )); then
	log "Syncing remote uploads"
	mkdir -p "${LOCAL_UPLOADS_PATH}"
	rsync_flags=(-az)
	if (( mirror_uploads )); then
		rsync_flags+=(--delete)
	fi
	run_with_retries "${SSH_RETRY_COUNT}" "${SSH_RETRY_DELAY}" \
		rsync "${rsync_flags[@]}" -e "${RSYNC_SSH_COMMAND}" "${REMOTE_SSH_HOST}:${REMOTE_UPLOADS_PATH}" "${LOCAL_UPLOADS_PATH}/"
fi

log "Local refresh complete."
