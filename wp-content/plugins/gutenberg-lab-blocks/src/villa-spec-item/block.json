{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/villa-spec-item",
	"version": "0.1.0",
	"title": "Villa Spec Item",
	"category": "design",
	"icon": "excerpt-view",
	"description": "One editable value and label pair used inside the Villa Specs block.",
	"parent": [ "gutenberg-lab-blocks/villa-specs" ],
	"attributes": {
		"value": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": ""
		}
	},
	"supports": {
		"html": false,
		"reusable": false
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js"
}
