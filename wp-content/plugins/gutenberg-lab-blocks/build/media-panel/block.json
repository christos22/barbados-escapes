{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenberg-lab-blocks/media-panel",
  "version": "0.1.0",
  "title": "Media Panel",
  "category": "design",
  "icon": "cover-image",
  "description": "A reusable media panel with overlaid content.",
  "example": {},
  "attributes": {
    "mediaType": {
      "type": "string",
      "default": "image"
    },
    "imageId": {
      "type": "number"
    },
    "imageUrl": {
      "type": "string",
      "default": ""
    },
    "imageAlt": {
      "type": "string",
      "default": ""
    },
    "videoId": {
      "type": "number"
    },
    "videoUrl": {
      "type": "string",
      "default": ""
    },
    "darkOverlay": {
      "type": "boolean",
      "default": false
    },
    "containerHeight": {
      "type": "string",
      "default": "medium"
    },
    "contentPosition": {
      "type": "string",
      "default": "center-center"
    },
    "fallbackImageId": {
      "type": "number"
    },
    "fallbackImageUrl": {
      "type": "string",
      "default": ""
    },
    "fallbackImageAlt": {
      "type": "string",
      "default": ""
    },
    "contentWidth": {
      "type": "string",
      "default": "md"
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "blockGap": true
    },
    "align": [
      "wide",
      "full"
    ]
  },
  "textdomain": "gutenberg-lab-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}