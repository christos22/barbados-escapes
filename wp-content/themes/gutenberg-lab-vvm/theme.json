{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "1320px",
			"wideSize": "1760px"
		},
		"useRootPaddingAwareAlignments": true,
		"custom": {
			"header": {
				"height": "96px"
			},
			"layout": {
				"gutterSm": "20px",
				"gutterLg": "40px",
				"gutterXl": "80px"
			},
			"hero": {
				"accent": "#79b395",
				"lineColor": "rgba(255,255,255,0.68)",
				"searchSurface": "rgba(248,243,235,0.94)",
				"searchText": "rgba(19,49,42,0.72)"
			}
		},
		"spacing": {
			"blockGap": true,
			"units": [ "px", "rem", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "2xs", "name": "2XS", "size": "0.375rem" },
				{ "slug": "xs", "name": "XS", "size": "0.75rem" },
				{ "slug": "sm", "name": "SM", "size": "1rem" },
				{ "slug": "md", "name": "MD", "size": "1.5rem" },
				{ "slug": "lg", "name": "LG", "size": "2.5rem" },
				{ "slug": "xl", "name": "XL", "size": "4rem" },
				{ "slug": "2xl", "name": "2XL", "size": "7rem" },
				{ "slug": "section-xs", "name": "Section XS", "size": "clamp(0.75rem, 1.2vw, 1.125rem)" },
				{ "slug": "section-sm", "name": "Section SM", "size": "clamp(1.5rem, 2vw, 2.25rem)" },
				{ "slug": "section-md", "name": "Section MD", "size": "clamp(3.125rem, 5vw, 4.375rem)" },
				{ "slug": "section-lg", "name": "Section LG", "size": "clamp(4.6875rem, 6.5vw, 6.5625rem)" },
				{ "slug": "section-xl", "name": "Section XL", "size": "clamp(6.25rem, 8vw, 8.75rem)" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Cormorant Garamond\", Georgia, serif",
					"name": "Display Serif",
					"slug": "display-serif"
				},
				{
					"fontFamily": "\"TT Norms\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
					"name": "TT Norms",
					"slug": "refined-sans",
					"fontFace": [
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Light.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Regular.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Medium.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Bold.otf" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xs", "name": "XS", "size": "0.875rem" },
				{ "slug": "sm", "name": "Small", "size": "0.9375rem" },
				{ "slug": "md", "name": "Medium", "size": "1.125rem" },
				{ "slug": "lg", "name": "Large", "size": "1.375rem" },
				{ "slug": "xl", "name": "XL", "size": "1.5rem" },
				{ "slug": "xxl", "name": "XXL", "size": "2.8125rem" },
				{ "slug": "hero", "name": "Hero", "size": "4rem" },
				{ "slug": "hero-display", "name": "Hero Display", "size": "clamp(3rem, 2.35rem + 1.65vw, 4rem)" }
			]
		},
		"color": {
			"palette": [
				{ "slug": "forest", "name": "Forest", "color": "#013223" },
				{ "slug": "deep-forest", "name": "Deep Forest", "color": "#0f2d23" },
				{ "slug": "teal-900", "name": "Teal 900", "color": "#0b3f41" },
				{ "slug": "teal-800", "name": "Teal 800", "color": "#114b4d" },
				{ "slug": "sand", "name": "Sand", "color": "#f6f1e8" },
				{ "slug": "mist", "name": "Mist", "color": "#dfe5e1" },
				{ "slug": "white", "name": "White", "color": "#ffffff" },
				{ "slug": "black", "name": "Black", "color": "#111111" }
			]
		}
	},
	"styles": {
		"css": ":root { --vvm-header-height: 96px; --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-sm); } @media (min-width: 1024px) { :root { --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-lg); } } @media (min-width: 1920px) { :root { --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-xl); } }",
		"color": {
			"text": "var(--wp--preset--color--deep-forest)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--refined-sans)",
			"fontSize": "15px",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var(--wp--custom--layout--gutter-current)",
				"right": "var(--wp--custom--layout--gutter-current)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--forest)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--teal-800)"
					}
				}
			},
			"button": {
				"border": {
					"radius": "3px"
				},
				"spacing": {
					"padding": {
						"top": "0.95rem",
						"bottom": "0.95rem",
						"left": "1.6rem",
						"right": "1.6rem"
					}
				},
				"typography": {
					"fontWeight": "400",
					"letterSpacing": "0.0625rem",
					"textTransform": "uppercase",
					"fontSize": "1rem"
				},
				"color": {
					"text": "var(--wp--preset--color--white)",
					"background": "var(--wp--preset--color--forest)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display-serif)",
					"fontWeight": "400",
					"lineHeight": "1.3",
					"letterSpacing": "normal"
				},
				"color": {
					"text": "var(--wp--preset--color--forest)"
				}
			},
			"paragraph": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "400",
					"lineHeight": "1.333333"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "clamp(3rem, 2.35rem + 1.65vw, 4rem)",
					"lineHeight": "1.3"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "clamp(2.25rem, 1.9rem + 0.95vw, 2.8125rem)",
					"lineHeight": "1.3"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--refined-sans)",
					"fontSize": "1rem",
					"fontWeight": "300",
					"letterSpacing": "0.0625rem",
					"textTransform": "uppercase",
					"lineHeight": "1.4"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "1.375rem",
					"fontWeight": "400",
					"letterSpacing": "0.0625rem",
					"lineHeight": "1"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "0.875rem",
					"fontWeight": "300",
					"letterSpacing": "0.0625rem",
					"textTransform": "uppercase"
				}
			},
			"core/button": {
				"border": {
					"radius": "3px"
				}
			},
			"core/buttons": {
				"spacing": {
					"margin": {
						"top": "clamp(0.75rem, 1.5vw, 1.25rem)"
					}
				}
			},
			"core/heading": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0.9375rem"
					}
				}
			},
			"core/site-logo": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/post-content": {
				"spacing": {
					"blockGap": "0"
				}
			},
			"gutenberg-lab-blocks/basic-content": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/split-content": {
				"spacing": {
					"blockGap": "clamp(0.75rem, 1.5vw, 1.25rem)",
					"margin": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/card-grid": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--lg)",
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/stack-tabs": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			}
		}
	}
}
