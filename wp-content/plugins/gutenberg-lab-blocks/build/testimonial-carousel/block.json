{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenberg-lab-blocks/testimonial-carousel",
  "version": "0.1.0",
  "title": "Testimonial Carousel",
  "category": "design",
  "icon": "format-quote",
  "description": "A centered quote carousel with optional faint background imagery.",
  "keywords": [
    "testimonial",
    "quote",
    "carousel",
    "slider"
  ],
  "attributes": {
    "backgroundImageId": {
      "type": "number"
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundImageAlt": {
      "type": "string",
      "default": ""
    },
    "backgroundImageOpacity": {
      "type": "number",
      "default": 35
    },
    "overlayOpacity": {
      "type": "number",
      "default": 70
    },
    "arrowPositionPreset": {
      "type": "string",
      "default": "center"
    },
    "arrowOffsetX": {
      "type": "number",
      "default": 0
    },
    "arrowOffsetY": {
      "type": "number",
      "default": 0
    },
    "accentBorder": {
      "type": "string",
      "default": "none"
    }
  },
  "supports": {
    "anchor": true,
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true,
      "text": true
    }
  },
  "textdomain": "gutenberg-lab-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js"
}