{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenberg-lab-blocks/card-grid",
  "version": "0.1.0",
  "title": "Card Grid",
  "category": "design",
  "icon": "screenoptions",
  "description": "A manual card grid section with native Gutenberg content inside each card.",
  "keywords": [
    "cards",
    "grid",
    "layout",
    "manual"
  ],
  "attributes": {
    "columns": {
      "type": "string",
      "default": "2"
    },
    "mediaRatio": {
      "type": "string",
      "default": "landscape"
    }
  },
  "supports": {
    "anchor": true,
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true
    }
  },
  "textdomain": "gutenberg-lab-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}