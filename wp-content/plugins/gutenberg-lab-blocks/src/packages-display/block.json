{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/packages-display",
	"version": "0.1.0",
	"title": "Packages Display",
	"category": "widgets",
	"icon": "screenoptions",
	"description": "Queries package posts and renders them in a grid or carousel.",
	"keywords": [ "packages", "grid", "carousel", "query" ],
	"attributes": {
		"displayMode": {
			"type": "string",
			"default": "grid"
		},
		"count": {
			"type": "number",
			"default": 3
		},
		"columns": {
			"type": "string",
			"default": "3"
		},
		"excludeCurrent": {
			"type": "boolean",
			"default": false
		},
		"showPackageType": {
			"type": "boolean",
			"default": true
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		},
		"showPrice": {
			"type": "boolean",
			"default": true
		},
		"showCta": {
			"type": "boolean",
			"default": false
		}
	},
	"usesContext": [ "postId", "postType", "queryId" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"anchor": true,
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": true
		}
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
