{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "100%",
			"wideSize": "100%"
		},
		"useRootPaddingAwareAlignments": true,
		"custom": {
			"brand": {
				"darkGreen": "#1E3D2F",
				"gold": "#C4922A",
				"lightGold": "#F5ECD7"
			},
			"header": {
				"height": "96px"
			},
			"layout": {
				"gutterSm": "20px",
				"gutterLg": "40px",
				"gutterXl": "80px"
			},
			"hero": {
				"accent": "#C4922A",
				"lineColor": "rgba(196,146,42,0.56)",
				"searchSurface": "rgba(245,236,215,0.94)",
				"searchText": "rgba(30,61,47,0.82)"
			}
		},
		"spacing": {
			"blockGap": true,
			"units": [ "px", "rem", "vw", "%" ],
			"spacingSizes": [
				{ "slug": "2xs", "name": "2XS", "size": "0.375rem" },
				{ "slug": "xs", "name": "XS", "size": "0.75rem" },
				{ "slug": "sm", "name": "SM", "size": "1rem" },
				{ "slug": "md", "name": "MD", "size": "1.5rem" },
				{ "slug": "lg", "name": "LG", "size": "2.5rem" },
				{ "slug": "xl", "name": "XL", "size": "4rem" },
				{ "slug": "2xl", "name": "2XL", "size": "7rem" },
				{ "slug": "section-xs", "name": "Section XS", "size": "clamp(0.75rem, 1.2vw, 1.125rem)" },
				{ "slug": "section-sm", "name": "Section SM", "size": "clamp(1.5rem, 2vw, 2.25rem)" },
				{ "slug": "section-md", "name": "Section MD", "size": "clamp(3.125rem, 5vw, 4.375rem)" },
				{ "slug": "section-lg", "name": "Section LG", "size": "clamp(4.6875rem, 6.5vw, 6.5625rem)" },
				{ "slug": "section-xl", "name": "Section XL", "size": "clamp(6.25rem, 8vw, 8.75rem)" }
			]
		},
		"typography": {
			"fluid": true,
			"customFontSize": true,
			"fontFamilies": [
				{
					"fontFamily": "\"Romely\", Georgia, serif",
					"name": "Romely Display",
					"slug": "display-serif"
				},
				{
					"fontFamily": "\"Romely\", Georgia, serif",
					"name": "Romely",
					"slug": "site-primary",
					"fontFace": [
						{
							"fontFamily": "Romely",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [ "file:./assets/fonts/romely/Romely Regular.ttf" ]
						}
					]
				},
				{
					"fontFamily": "\"TT Norms\", system-ui, -apple-system, \"Segoe UI\", sans-serif",
					"name": "TT Norms",
					"slug": "refined-sans",
					"fontFace": [
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Light.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Regular.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Medium.otf" ]
						},
						{
							"fontFamily": "TT Norms",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [ "file:./assets/fonts/tt-norms/TT-Norms-Bold.otf" ]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "xs", "name": "XS", "size": "0.75rem", "fluid": false },
				{ "slug": "sm", "name": "Small", "size": "0.8125rem", "fluid": false },
				{ "slug": "md", "name": "Medium", "size": "0.875rem", "fluid": false },
				{ "slug": "lg", "name": "Large", "size": "1rem", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "slug": "xl", "name": "XL", "size": "1.375rem", "fluid": { "min": "1.25rem", "max": "1.5rem" } },
				{ "slug": "two-xl", "name": "2XL", "size": "1.75rem", "fluid": { "min": "1.5rem", "max": "2rem" } },
				{ "slug": "three-xl", "name": "3XL", "size": "2rem", "fluid": { "min": "1.75rem", "max": "2.25rem" } },
				{ "slug": "four-xl", "name": "4XL", "size": "2.25rem", "fluid": { "min": "2rem", "max": "2.8125rem" } },
				{ "slug": "five-xl", "name": "5XL", "size": "4rem", "fluid": { "min": "3rem", "max": "4rem" } },
				{ "slug": "six-xl", "name": "6XL", "size": "4.5rem", "fluid": { "min": "3.25rem", "max": "4.5rem" } }
			]
		},
		"color": {
			"palette": [
				{ "slug": "dark-green", "name": "Dark Green", "color": "#1E3D2F" },
				{ "slug": "gold", "name": "Gold", "color": "#C4922A" },
				{ "slug": "light-gold", "name": "Light Gold", "color": "#F5ECD7" },
				{ "slug": "forest", "name": "Forest", "color": "#1E3D2F" },
				{ "slug": "deep-forest", "name": "Deep Forest", "color": "#1E3D2F" },
				{ "slug": "teal-900", "name": "Teal 900", "color": "#1E3D2F" },
				{ "slug": "teal-800", "name": "Teal 800", "color": "#C4922A" },
				{ "slug": "sand", "name": "Sand", "color": "#F5ECD7" },
				{ "slug": "mist", "name": "Mist", "color": "#F5ECD7" },
				{ "slug": "white", "name": "White", "color": "#ffffff" },
				{ "slug": "black", "name": "Black", "color": "#111111" }
			]
		}
	},
	"styles": {
		"css": ":root { --vvm-header-height: 96px; --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-sm); } @media (min-width: 1024px) { :root { --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-lg); } } @media (min-width: 1920px) { :root { --wp--custom--layout--gutter-current: var(--wp--custom--layout--gutter-xl); } }",
		"color": {
			"text": "var(--wp--preset--color--dark-green)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--site-primary)",
			"fontSize": "15px",
			"fontWeight": "400",
			"lineHeight": "1.6"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var(--wp--custom--layout--gutter-current)",
				"right": "var(--wp--custom--layout--gutter-current)"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--dark-green)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--gold)"
					}
				}
			},
			"button": {
				"border": {
					"radius": "0"
				},
				"spacing": {
					"padding": {
						"top": "12px",
						"bottom": "12px",
						"left": "32px",
						"right": "32px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--site-primary)",
					"fontWeight": "600",
					"letterSpacing": "0.15em",
					"textTransform": "uppercase",
					"fontSize": "18px"
				},
				"color": {
					"text": "var(--wp--preset--color--dark-green)",
					"background": "var(--wp--preset--color--gold)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--display-serif)",
					"fontWeight": "400",
					"lineHeight": "1.3",
					"letterSpacing": "normal"
				},
				"color": {
					"text": "var(--wp--preset--color--dark-green)"
				}
			},
			"paragraph": {
				"typography": {
					"fontSize": "1.125rem",
					"fontWeight": "400",
					"lineHeight": "1.333333"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|five-xl"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|four-xl"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|three-xl"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--refined-sans)",
					"fontSize": "clamp(0.6875rem, 0.66rem + 0.18vw, 0.75rem)",
					"fontWeight": "400",
					"letterSpacing": "0.34em",
					"textTransform": "uppercase",
					"lineHeight": "1rem"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|xl",
					"fontWeight": "400",
					"letterSpacing": "0.0625rem",
					"lineHeight": "1"
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "0.875rem",
					"fontWeight": "300",
					"letterSpacing": "0.0625rem",
					"textTransform": "uppercase"
				}
			},
			"core/button": {
				"border": {
					"radius": "0"
				}
			},
			"core/buttons": {
				"spacing": {
					"margin": {
						"top": "clamp(0.75rem, 1.5vw, 1.25rem)"
					}
				}
			},
			"core/heading": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0.9375rem"
					}
				}
			},
			"core/site-logo": {
				"spacing": {
					"margin": {
						"top": "0",
						"bottom": "0"
					}
				}
			},
			"core/post-content": {
				"spacing": {
					"blockGap": "0"
				}
			},
			"gutenberg-lab-blocks/basic-content": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/value-pillars": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--lg)",
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/split-content": {
				"spacing": {
					"blockGap": "clamp(0.75rem, 1.5vw, 1.25rem)",
					"margin": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/card-grid": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--lg)",
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			},
			"gutenberg-lab-blocks/stack-tabs": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--section-md)",
						"bottom": "var(--wp--preset--spacing--section-md)"
					}
				}
			}
		}
	}
}
