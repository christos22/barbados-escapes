{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "gutenberg-lab-blocks/card-carousel",
  "version": "0.1.5",
  "title": "Card Carousel",
  "category": "design",
  "icon": "images-alt2",
  "description": "A split intro and card carousel that can be authored manually or populated from villa posts.",
  "keywords": [
    "carousel",
    "cards",
    "slider",
    "villas"
  ],
  "attributes": {
    "contentSource": {
      "type": "string",
      "default": "manual"
    },
    "villaCount": {
      "type": "number",
      "default": 3
    },
    "arrowPositionPreset": {
      "type": "string",
      "default": "center"
    },
    "arrowOffsetX": {
      "type": "number",
      "default": 0
    },
    "arrowOffsetY": {
      "type": "number",
      "default": 0
    }
  },
  "supports": {
    "anchor": true,
    "html": false,
    "align": [
      "wide",
      "full"
    ],
    "spacing": {
      "margin": [
        "top",
        "bottom"
      ],
      "padding": true,
      "blockGap": true
    },
    "color": {
      "background": true
    }
  },
  "textdomain": "gutenberg-lab-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScript": "file:./view.js"
}