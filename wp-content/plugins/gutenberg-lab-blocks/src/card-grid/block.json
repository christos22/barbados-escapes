{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/card-grid",
	"version": "0.1.0",
	"title": "Card Grid",
	"category": "design",
	"icon": "screenoptions",
	"description": "A card grid that can be authored manually or populated from villa posts.",
	"keywords": [ "cards", "grid", "layout", "villas" ],
	"attributes": {
		"contentSource": {
			"type": "string",
			"default": "manual"
		},
		"villaCount": {
			"type": "number",
			"default": 3
		},
		"villaPresentation": {
			"type": "string",
			"default": "cinematic"
		},
		"columns": {
			"type": "string",
			"default": "2"
		},
		"enableCarousel": {
			"type": "boolean",
			"default": false
		},
		"mediaRatio": {
			"type": "string",
			"default": "landscape"
		},
		"arrowPositionPreset": {
			"type": "string",
			"default": "center"
		},
		"arrowOffsetX": {
			"type": "number",
			"default": 0
		},
		"arrowOffsetY": {
			"type": "number",
			"default": 0
		}
	},
	"supports": {
		"anchor": true,
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": true,
			"blockGap": true
		},
		"color": {
			"background": true
		}
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
