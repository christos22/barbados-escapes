{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/media-panel",
	"version": "0.1.0",
	"title": "Media Panel",
	"category": "design",
	"icon": "cover-image",
	"description": "A reusable media panel with overlaid content.",
	"example": {},
	"attributes": {
		"mediaType": {
			"type": "string",
			"default": "image"
		},
		"imageId": {
			"type": "number"
		},
		"imageUrl": {
			"type": "string",
			"default": ""
		},
		"imageAlt": {
			"type": "string",
			"default": ""
		},
		"videoId": {
			"type": "number"
		},
		"videoUrl": {
			"type": "string",
			"default": ""
		},
		"darkOverlay": {
			"type": "boolean",
			"default": false
		},
		"overlayGradientStyle": {
			"type": "string",
			"default": "brand-green"
		},
		"contentStyle": {
			"type": "string",
			"default": "overlay"
		},
		"containerHeight": {
			"type": "string",
			"default": "medium"
		},
		"contentPosition": {
			"type": "string",
			"default": "center-center"
		},
		"fallbackImageId": {
			"type": "number"
		},
		"fallbackImageUrl": {
			"type": "string",
			"default": ""
		},
		"fallbackImageAlt": {
			"type": "string",
			"default": ""
		},
		"contentWidth": {
			"type": "string",
			"default": "md"
		},
		"accentBorder": {
			"type": "string",
			"default": "none"
		},
		"atmosphereEdge": {
			"type": "string",
			"default": "none"
		},
		"curtainParallax": {
			"type": "boolean",
			"default": false
		}
	},
	"supports": {
		"html": false,
		"spacing": {
			"margin": [ "top", "bottom" ],
			"blockGap": true
		},
		"align": [
			"wide",
			"full"
		]
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php"
}
