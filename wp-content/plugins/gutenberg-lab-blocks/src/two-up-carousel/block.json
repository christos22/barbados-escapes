{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/two-up-carousel",
	"version": "0.1.0",
	"title": "Two-Up Carousel",
	"category": "design",
	"icon": "images-alt2",
	"description": "A reusable carousel that shows two featured slides at a time with adjacent slides partially visible.",
	"keywords": [ "two-up", "carousel", "paired", "slider" ],
	"supports": {
		"anchor": true,
		"html": false,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": true
		},
		"color": {
			"background": true
		}
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
