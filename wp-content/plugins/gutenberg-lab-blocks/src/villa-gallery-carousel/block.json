{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "gutenberg-lab-blocks/villa-gallery-carousel",
	"version": "0.1.4",
	"title": "Villa Gallery Carousel",
	"category": "design",
	"icon": "images-alt2",
	"description": "A compact villa gallery rail styled like the hero thumbnails.",
	"keywords": [ "villa", "gallery", "carousel", "slider" ],
	"attributes": {
		"arrowPositionPreset": {
			"type": "string",
			"default": "center"
		},
		"arrowOffsetX": {
			"type": "number",
			"default": 0
		},
		"arrowOffsetY": {
			"type": "number",
			"default": 0
		},
		"isCardInteractive": {
			"type": "boolean",
			"default": true
		}
	},
	"supports": {
		"html": false,
		"anchor": true,
		"align": [ "wide", "full" ],
		"spacing": {
			"margin": [ "top", "bottom" ],
			"padding": true
		}
	},
	"textdomain": "gutenberg-lab-blocks",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}
