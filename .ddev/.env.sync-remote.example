# Copy this file to `.ddev/.env.sync-remote` and replace the placeholder values
# with the production server database credentials before running remote DB syncs.

REMOTE_SSH_HOST=inmotion-grapsasdev
REMOTE_WP_PATH=/home/grapsa5/barbadosescapes.com
REMOTE_DB_HOST='localhost'
REMOTE_DB_NAME='replace_with_production_db_name'
REMOTE_DB_USER='replace_with_production_db_user'
REMOTE_DB_PASSWORD='replace_with_production_db_password'
REMOTE_SITE_URL=https://barbadosescapes.com
LOCAL_SITE_URL=https://barbados-escapes.ddev.site
REMOTE_EXPECTED_TABLE_PREFIX=vvm_

# Optional: where ddev push-remote stores pre-import remote DB backups.
# Defaults to "${REMOTE_WP_PATH}/../barbados-db-backups".
# REMOTE_DB_BACKUP_DIR=/home/grapsa5/barbados-db-backups

# Optional: where ddev push-post stores backups of posts it updates remotely.
# Defaults to a `barbados-post-backups` directory beside the WordPress docroot.
# REMOTE_POST_BACKUP_DIR=/home/grapsa5/barbados-post-backups
